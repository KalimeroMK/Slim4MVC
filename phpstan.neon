parameters:
    level: 8
    reportUnmatchedIgnoredErrors: false
    paths:
        - app
        - bootstrap
        - routes
    excludePaths:
        - vendor
        - storage
        - stubs
        - tests
    scanFiles:
        - vendor/autoload.php
    ignoreErrors:
        # Ignore helper functions
        - '#Function view not found#'
        - '#Function route not found#'
        - '#Function url not found#'
        - '#Function asset not found#'
        # Starter-kit traits are intentionally available for users to opt-in
        - '#Trait App\\Modules\\Core\\Infrastructure\\Cache\\Cacheable is used zero times#'
        - '#Trait App\\Modules\\Core\\Infrastructure\\Cache\\RepositoryCacheExample is used zero times#'
        - '#Trait App\\Modules\\Core\\Infrastructure\\Query\\Filterable is used zero times#'
