parameters:
    level: 8
    reportUnmatchedIgnoredErrors: false
    paths:
        - app
        - bootstrap
        - routes
    excludePaths:
        - vendor
        - storage
        - stubs
        - tests
    scanFiles:
        - vendor/autoload.php
    ignoreErrors:
        # Ignore helper functions
        - '#Function view not found#'
        - '#Function route not found#'
        - '#Function url not found#'
        - '#Function asset not found#'
