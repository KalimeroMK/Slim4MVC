            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/password-recovery",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "password-recovery"]
            },
            "description": "Request password reset link via email"
