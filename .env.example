# Application Environment
APP_ENV=local
APP_URL=http://localhost

# Docker Configuration
NGINX_PORT=80
DB_PORT=3307
REDIS_PORT=6379

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=slim_db
DB_PORT=3306
DB_DATABASE=slim
DB_USERNAME=slim
DB_PASSWORD=secret
DB_ROOT_PASSWORD=secret

# Redis Configuration
REDIS_HOST=slim_redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# JWT Configuration
JWT_SECRET=supersecretkey123

# Mail Configuration
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_password
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Your App Name"
MAIL_ENCRYPTION=tls

# CORS Configuration
CORS_ORIGINS=*

# Trusted Proxies (comma-separated IPs — set when behind a load balancer/reverse proxy)
TRUSTED_PROXIES=

# Queue Configuration
QUEUE_DRIVER=redis
QUEUE_RETRY_AFTER=90

# Cache Configuration
CACHE_DRIVER=redis
CACHE_PREFIX=slim_cache
CACHE_PATH=/var/www/html/storage/cache/data
REDIS_CACHE_DATABASE=1

# Cookie Configuration
COOKIE_TTL=3600
COOKIE_PATH=/
COOKIE_DOMAIN=
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=Lax
COOKIE_ENCRYPT=true

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Eloquent ORM Configuration
# Enable auto eager loading globally (true/false)
ELOQUENT_AUTO_EAGER_LOADING=false

# Auto eager loading mode: 'explicit' or 'detection'
# - explicit: Only models with `autoWith` property are auto-loaded
# - detection: Auto-detect all relations (can impact performance)
ELOQUENT_AUTO_MODE=explicit

# Lazy loading detection (development only - throws exception on N+1)
ELOQUENT_LAZY_LOADING_DETECTION=false
